# ==========================================
# VENDORNET ENVIRONMENT VARIABLES CONFIG
# ==========================================

# 1. SERVER CONFIGURATION
# The port number where your Node.js backend server will run (e.g., http://localhost:5000)
PORT=5000

# 2. DATABASE CONFIGURATION (MongoDB Atlas Connection Strings)
# We set both names so whichever one your code calls (MONGO_URI or MONGODB_URI) will work.
MONGO_URI=mongodb+srv://kotadiasaavi_db_user:dk52Cw4yT9AS5uHQ@cluster0.qfkdavo.mongodb.net/vendornest?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb+srv://kotadiasaavi_db_user:dk52Cw4yT9AS5uHQ@cluster0.qfkdavo.mongodb.net/vendornest?retryWrites=true&w=majority&appName=Cluster0

# 3. ACCESS TOKEN (Short-lived key for authorizing requests)
# JWT_SECRET is the password Node.js uses to lock/sign the access token. 
# Think of this like a signature stamp that only your server knows.
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1d

# If your code uses "ACCESS_TOKEN_SECRET" instead of "JWT_SECRET", these are mapped here:
ACCESS_TOKEN_SECRET=your_super_secret_jwt_key_here
ACCESS_TOKEN_EXPIRY=1d

# 4. REFRESH TOKEN (Long-lived key to generate new access tokens when they expire)
# This lets the user stay logged in without typing their password every single day.
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRY=7d

# 5. SECURITY CONFIGURATION
# Allows your frontend application (e.g., React on port 5173 or 3000) to communicate with this backend.
# "*" means any frontend is allowed to make requests.
CORS_ORIGIN=*